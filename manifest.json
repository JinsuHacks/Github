{
  "manifest_version": 3,
  "name": "SmoothActions",
  "description": "One-click automations for repetitive web tasks.",
  "version": "1.0.0",
"icons": {
  "16": "icons/icon128.png",
  "32": "icons/icon128.png",
  "48": "icons/icon128.png",
  "128": "icons/icon128.png"
},
"action": {
  "default_popup": "popup.html",
  "default_icon": {
    "16": "icons/icon128.png",
    "32": "icons/icon128.png"
  }
},
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabs",
    "scripting",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
  ,
  "web_accessible_resources": [
    {
      "resources": ["copycode.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
